#xA;&lt;/style&gt;&#xA;&lt;/head&gt;&#xA;&lt;body&gt;&#xA;&#xA;&lt;div class='container'&gt;&#xA;    &lt;!-- Üst Başlık (Renk Değişken) --&gt;&#xA;    &lt;div class='header' style='background-color: &quot; + Sprint_Health_Color + &quot;;'&gt;&#xA;        &lt;h1&gt;Sprint Sonuç Raporu&lt;/h1&gt;&#xA;        &lt;p&gt;&quot; + Now.ToString(&quot;dd MMMM yyyy dddd&quot;) + &quot;&lt;/p&gt;&#xA;        &lt;div style='font-size: 18px; font-weight: 500; margin-top: 15px; background: rgba(255,255,255,0.2); display: inline-block; padding: 5px 20px; border-radius: 20px;'&gt;&#xA;            &quot; + CarryOver_Risk_Text + &quot;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;!-- KPI Kartları --&gt;&#xA;    &lt;div class='metrics'&gt;&#xA;        &lt;div class='metric-box'&gt;&#xA;            &lt;span class='metric-num' style='color: #2980b9;'&gt;&quot; + Total_Closed.ToString + &quot;&lt;/span&gt;&#xA;            &lt;span class='metric-desc'&gt;Tamamlanan İş&lt;/span&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div class='metric-box'&gt;&#xA;            &lt;span class='metric-num' style='color: #e67e22;'&gt;&quot; + in_OpenIssues.Count.ToString + &quot;&lt;/span&gt;&#xA;            &lt;span class='metric-desc'&gt;Devreden İş (Open)&lt;/span&gt;&#xA;        &lt;/div&gt;&#xA;        &lt;div class='metric-box'&gt;&#xA;            &lt;span class='metric-num' style='color: &quot; + If(Unfinished_ToDo_Count &gt; 0, &quot;#c0392b&quot;, &quot;#27ae60&quot;) + &quot;;'&gt;&quot; + Unfinished_ToDo_Count.ToString + &quot;&lt;/span&gt;&#xA;            &lt;span class='metric-desc'&gt;Başlanmamış (To Do)&lt;/span&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;!-- BÖLÜM 1: DEVREDEN İŞ RİSK ANALİZİ --&gt;&#xA;    &lt;div class='section'&gt;&#xA;        &lt;h3&gt;📉 Devreden İşlerin Durumu (Carry-over Analysis)&lt;/h3&gt;&#xA;        &lt;p style='font-size: 14px; color: #555; line-height: 1.5;'&gt;&#xA;            Sprint sona ererken &quot; + in_OpenIssues.Count.ToString + &quot; iş tamamlanamadı ve bir sonraki sprinte devredildi.&#xA;            &quot; + If(Unfinished_ToDo_Count &gt; 0, &quot;&lt;span class='risk-text'&gt;DİKKAT:&lt;/span&gt; Devreden işlerin &quot; + Unfinished_ToDo_Count.ToString + &quot; tanesi 'To Do' statüsünde. Bu işlerin üzerinde çalışılmamış bile değil, bu durum bir sonraki sprintin planını ciddi şekilde sıkıştırabilir.&quot;, &quot;Tüm devreden işler 'In Progress' statüsünde. Ekip işlere odaklanmış, sadece süre yetmemiş.&quot;) + &quot;&#xA;        &lt;/p&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;!-- BÖLÜM 2: YÖNETİCİ RİSK UYARILARI --&gt;&#xA;    &lt;div class='section'&gt;&#xA;        &lt;h3&gt;🚨 Yönetici Risk Paneli&lt;/h3&gt;&#xA;        &#xA;        &quot; + If(Unassigned_Critical_Count &gt; 0, &quot;&lt;div class='alert-box'&gt;&lt;strong&gt;Sahipsiz Kritik İş:&lt;/strong&gt; &quot; + Unassigned_Critical_Count.ToString + &quot; adet Kritik/Highest öncelikli iş var ve henüz kime atanacağı belli değil. Bu işler bir sonraki sprintin başında gecikmelere neden olabilir.&lt;/div&gt;&quot;, &quot;&quot;) + &quot;&#xA;&#xA;        &quot; + If(Stalled_InProgress_Count &gt; 0, &quot;&lt;div class='alert-box' style='border-left-color: #e67e22; background-color: #fff8e1; color: #8d6e63;'&gt;&lt;strong&gt;Takılmış İşler (Stalled):&lt;/strong&gt; &quot; + Stalled_InProgress_Count.ToString + &quot; adet iş 'In Progress' olmasına rağmen son 3 gündür güncellenmemiş. Bu işler engellenebilir (Blocked) durumda olabilir.&lt;/div&gt;&quot;, &quot;&quot;) + &quot;&#xA;&#xA;        &quot; + If(Unassigned_Critical_Count = 0 And Stalled_InProgress_Count = 0, &quot;&lt;p style='color: #27ae60; font-weight: bold; text-align: center;'&gt;✅ Herhangi bir operasyonel risk tespit edilmedi. İş akışı sağlıklı.&lt;/p&gt;&quot;, &quot;&quot;) + &quot;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;!-- BÖLÜM 3: PERSONEL YÜK VE VERİMLİLİK --&gt;&#xA;    &lt;div class='section' style='border-bottom: none;'&gt;&#xA;        &lt;h3&gt;👥 Personel Yük Dağılımı&lt;/h3&gt;&#xA;        &lt;table&gt;&#xA;            &lt;tr&gt;&#xA;                &lt;th&gt;En Çok İş Alan Kişi&lt;/th&gt;&#xA;                &lt;td&gt;&quot; + Most_Assigned_User + &quot;&lt;/td&gt;&#xA;            &lt;/tr&gt;&#xA;            &lt;tr&gt;&#xA;                &lt;th&gt;En Az İş Alan Kişi&lt;/th&gt;&#xA;                &lt;td&gt;&quot; + Least_Assigned_User + &quot;&lt;/td&gt;&#xA;            &lt;/tr&gt;&#xA;        &lt;/table&gt;&#xA;        &lt;p style='font-size: 12px; color: #999; margin-top: 10px;'&gt;*Veriler, sprint kapanış anındaki 'Open' statülü işlere dayanmaktadır.&lt;/p&gt;&#xA;    &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/body&gt;&#xA;&lt;/html&gt;&quot;]" />
